# ==============================================================================
# Wedding Website - Environment Variables Template
# Copy this file to '.env.local' and fill in your credentials.
# Do NOT commit '.env.local' or any files containing actual keys to Git.
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase Configuration
# ------------------------------------------------------------------------------
# Your Supabase Project API URL (found in Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anonymous key (safe to expose in client code, respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (secret, bypasses RLS, used for setup/sync scripts)
# WARNING: Keep this secret and NEVER commit it or expose it in client code!
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ------------------------------------------------------------------------------
# Mapbox Configuration
# ------------------------------------------------------------------------------
# Public access token for Mapbox (starts with 'pk.') to render location maps
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here

# ------------------------------------------------------------------------------
# Google Gemini API
# ------------------------------------------------------------------------------
# API key for the Gemini model used by the AI wedding concierge chat assistant
GEMINI_API_KEY=your_gemini_api_key_here
